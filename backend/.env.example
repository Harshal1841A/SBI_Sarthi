# SARTHI API Environment Variables
# NEVER commit the real .env file — this is a template only

# LLM API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BHASHINI_API_KEY=bhashini_xxxxxxxxxxxxxxxx

# Security Secrets (generate once with: python -c "import secrets; print(secrets.token_hex(32))")
SARTHI_HMAC_SECRET=GENERATE_ME_run_python_c_import_secrets_print_secrets.token_hex32
SARTHI_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SARTHI_SUPERVISOR_TOKEN=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Database
SQLITE_PATH=/data/checkpoints.db

# Optional: Production overrides
# REDIS_URL=redis://localhost:6379
# POSTGRES_URL=postgresql://user:pass@localhost/sarthi
